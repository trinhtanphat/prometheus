# Copy to .env for local use. Store production values in AWS Secrets Manager or Vault.
GRAFANA_ADMIN_USER=admin@vnso.vn
GRAFANA_ADMIN_PASSWORD=replace-with-secret-manager-value
WANGUARD_API_URL=http://console-mgmt.vnso.local/api/v1
WANGUARD_API_TOKEN=replace-with-wanguard-api-token
SLACK_WEBHOOK_DEFAULT=https://hooks.slack.com/services/replace/me
SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/replace/me
PAGERDUTY_ROUTING_KEY=replace-with-pagerduty-routing-key
CLICKHOUSE_PASSWORD=replace-with-clickhouse-password